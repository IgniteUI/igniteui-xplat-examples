<UserControl
    x:Class="Sample.Sample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ig="using:Infragistics.Controls"
    <!-- ifdef charts -->
    xmlns:igCharts="using:Infragistics.Controls.Charts"
    <!-- endifdef charts -->
    <!-- ifdef maps -->
    xmlns:igMaps="using:Infragistics.Controls.Maps"
    <!-- endifdef maps -->
    <!-- ifdef data-grids -->
    xmlns:igDataGrids="using:Infragistics.Controls.Grids"
    <!-- endifdef data-grids -->
    <!-- ifdef gauges -->
    xmlns:igGauges="using:Infragistics.Controls.Gauges"
    <!-- endifdef gauges -->
    <!-- ifdef inputs -->
    xmlns:igInputs="using:Infragistics.Controls.Inputs"
    <!-- endifdef inputs -->
    <!-- ifdef layouts -->
    xmlns:igLayouts="using:Infragistics.Controls.Layouts"
    <!-- endifdef layouts -->
    <!-- ifdef dashboards -->
    xmlns:igDashboards="using:Infragistics.Controls.Dashboards"
    <!-- endifdef dashboards -->
    mc:Ignorable="d">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition />
      </Grid.RowDefinitions>
      <StackPanel>
        <!-- ifdef editor -->
        <Grid>
          <!-- insert editor -->
          <!-- end editor-->
        </Grid>
        <!-- endifdef editor -->
        <!-- ifdef legend -->
        <Grid>
          <!-- insert legend -->
          <!-- end legend -->
        </Grid>
        <!-- endifdef legend -->
        <!-- ifdef aboveContent -->
        <Grid>
          <!-- insert aboveContent -->
          <!-- end aboveContent -->
        </Grid>
        <!-- endifdef aboveContent -->
        <!-- ifdef aboveContentLeft, aboveContentRight -->
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <!-- ifdef aboveContentLeft -->
          <Grid Grid.Column="0" HorizontalAlignment="Left" Margin="10 0 0 0">
            <!-- insert aboveContentLeft -->
            <!-- end aboveContentLeft -->
          </Grid>
          <!-- endifdef aboveContentLeft -->
          <!-- ifdef aboveContentRight -->
          <Grid Grid.Column="1" HorizontalAlignment="Right" Margin="0 0 10 0">
            <!-- insert aboveContentRight -->
            <!-- end aboveContentRight -->
          </Grid>
          <!-- endifdef aboveContentRight -->
        </Grid>
        <!-- endifdef aboveContentLeft, aboveContentRight -->
      </StackPanel>
      <Grid Grid.Row="1">
        <!-- insert content -->
        <!-- end content -->
      </Grid>
    </Grid>
</UserControl>
