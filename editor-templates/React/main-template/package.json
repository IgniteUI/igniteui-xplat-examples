{
  "name": "example-ignite-ui-react",
  "description": "This project provides example of using Ignite UI for React components",
  "author": "Infragistics",
  "version": "1.4.0",
  "license": "",
  "homepage": ".",
  "private": true,
  "scripts": {
    "start": "vite --port 4200",
    "build": "tsc && node --max-old-space-size=4096 node_modules/vite/bin/vite build",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint ./src/**/*.{ts,tsx}"
  },
  "dependencies": {
    "igniteui-react-core": "19.3.2",
//ifdef webgrids
    "igniteui-dockmanager": "^1.17.0",
//endifdef webgrids
    "igniteui-react": "^19.5.0",
//ifdef charts, maps, dashboards
    "igniteui-react-charts": "19.3.2",
//endifdef charts, maps, dashboards
//ifdef dashboards
    "igniteui-react-dashboards": "19.3.2",
	"igniteui-react-data-grids": "19.3.2",
//endifdef dashboards
//ifdef data-grids
    "igniteui-react-data-grids": "19.3.2",
//endifdef data-grids
//ifdef grid, dashboards
    "igniteui-react-datasources": "19.3.2",
//endifdef grid, dashboards
//ifdef excel, spreadsheet
    "igniteui-react-excel": "19.3.2",
//endifdef excel, spreadsheet
//ifdef gauges, dashboards
    "igniteui-react-gauges": "19.3.2",
//endifdef gauges, dashboards
//ifdef webgrids
    "igniteui-react-grids": "^19.5.0",
//endifdef webgrids
//ifdef grid, dashboards
    "igniteui-react-data-grids": "19.3.2",
//endifdef grid, dashboards
//ifdef grid, inputs, layouts, editor, dashboards
    "igniteui-react-inputs": "19.3.2",
//endifdef grid, inputs, layouts, editor, dashboards
//ifdef grid, editor, layouts, dashboards
    "igniteui-react-layouts": "19.3.2",
//endifdef grid, editor, layouts, dashboards
//ifdef maps, dashboards
    "igniteui-react-maps": "19.3.2",
//endifdef maps, dashboards
//ifdef spreadsheet
    "igniteui-react-spreadsheet": "19.3.2",
    "igniteui-react-spreadsheet-chart-adapter": "19.3.2",
//endifdef spreadsheet
    "igniteui-webcomponents": "^7.0.0",
    "lit-html": "^3.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tslib": "^2.4.0"
  },
  "devDependencies": {
    "@types/jest": "^29.2.0",
    "@types/node": "^24.7.1",
    "@types/react": "^18.0.24",
    "@types/react-dom": "^18.0.8",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/browser": "^3.2.4",
    "eslint": "^8.33.0",
    "eslint-config-react": "^1.1.7",
    "eslint-plugin-react": "^7.20.0",
    "typescript": "^4.8.4",
    "vite": "^7.1.9",
    "vitest": "^3.2.4",
    "vitest-canvas-mock": "^0.3.3",
    "worker-loader": "^3.0.8"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ]
}
