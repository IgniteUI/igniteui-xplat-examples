{
  "name": "example-ignite-ui-react",
  "description": "This project provides example of using Ignite UI for React components",
  "author": "Infragistics",
  "version": "1.4.0",
  "license": "",
  "homepage": ".",
  "private": true,
  "scripts": {
    "start": "set PORT=4200 && react-scripts --max_old_space_size=10240 start",
    "build": "react-scripts --max_old_space_size=10240 build ",
    "test": "react-scripts test --env=jsdom",
    "eject": "react-scripts eject",
    "lint": "eslint ./src/**/*.{ts,tsx}"
  },
  "dependencies": {
    "igniteui-react-core": "19.0.0-alpha.1",
//ifdef webgrids
    "igniteui-dockmanager": "1.16.1",
//endifdef webgrids
    "igniteui-react": "19.0.2",
//ifdef charts, maps, dashboards
    "igniteui-react-charts": "19.0.0-alpha.1",
//endifdef charts, maps, dashboards
//ifdef dashboards
    "igniteui-react-dashboards": "19.0.0-alpha.1",
//endifdef dashboards
//ifdef grid, webgrids, dashboards
    "igniteui-react-datasources": "19.0.0-alpha.1",
//endifdef grid, webgrids, dashboards
//ifdef excel, spreadsheet
    "igniteui-react-excel": "19.0.0-alpha.1",
//endifdef excel, spreadsheet
//ifdef gauges, dashboards
    "igniteui-react-gauges": "19.0.0-alpha.1",
//endifdef gauges, dashboards
//ifdef grid, webgrids, dashboards
    "igniteui-react-grids": "19.0.2",
//endifdef grid, webgrids, dashboards
//ifdef grid, webgrids, inputs, layouts, editor, dashboards
    "igniteui-react-inputs": "19.0.0-alpha.1",
//endifdef grid, webgrids, inputs, layouts, editor, dashboards
//ifdef grid, webgrids, editor, layouts, dashboards
    "igniteui-react-layouts": "19.0.0-alpha.1",
//endifdef grid, webgrids, editor, layouts, dashboards
//ifdef maps, dashboards
    "igniteui-react-maps": "19.0.0-alpha.1",
//endifdef maps, dashboards
//ifdef spreadsheet
    "igniteui-react-spreadsheet": "19.0.0-alpha.1",
    "igniteui-react-spreadsheet-chart-adapter": "19.0.0-alpha.1",
//endifdef spreadsheet
    "igniteui-webcomponents": "6.0.0",
    "lit-html": "^3.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "^5.0.1",
    "tslib": "^2.4.0"
  },
  "devDependencies": {
    "@types/jest": "^29.2.0",
    "@types/node": "^18.11.7",
    "@types/react": "^18.0.24",
    "@types/react-dom": "^18.0.8",
    "eslint": "^8.33.0",
    "eslint-config-react": "^1.1.7",
    "eslint-plugin-react": "^7.20.0",
    "react-app-rewired": "^2.2.1",
    "typescript": "^4.8.4",
    "worker-loader": "^3.0.8"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ]
}
