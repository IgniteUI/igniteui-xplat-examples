{
  "skipAlterDataCasing": true,
  "onViewInit": [
    "DataGridRegisterCountryFilterOnViewInit",
    "DataGridRegisterCustomAgeFilterOnViewInit"
  ],
  "descriptions": {
    "content": {
      "type": "DataGrid",
      "id": "grid",
      "name": "grid",
      "dataSourceRef": "EmployeesSalesData",
      "autoGenerateColumns": false,
      "defaultColumnMinWidth": 100,
      "isColumnOptionsEnabled": true,
      "filterUIType": "FilterRow",
      "height": "100%",
      "width": "100%",
      "columns": [
        {
          "type": "TextColumn",
          "field": "Country",
          "headerText": "Code-behind Filter*",
          "width": { "type": "ColumnWidth", "isStarSized": true, "value": 1, "minimumWidth": 170 }
        },
        {
          "type": "NumericColumn",
          "field": "Age",
          "headerText": "Custom Class Filter**"
        },
        {
          "type": "NumericColumn",
          "field": "Sales",
          "headerText": "In-line Filter***",
          "width": { "type": "ColumnWidth", "isStarSized": true, "value": 1, "minimumWidth": 120 },
          "positivePrefix": "$",
          "showGroupingSeparator": true,
          "filterOperands": [
            {
              "type": "FilterOperand",
              "editorType": "Numeric",
              "isInputRequired": false,
              "displayName": "(Custom) In-Line Filter",
              "filterRequestedRef": "DataGridFilterSalesLessThanOrEqual300k"
            }
          ]
        }
      ]
    }
  },
  "modules": ["grids/DataGridModule"]
}
