{
  "skipAlterDataCasing": true,
  "descriptions": {
    "editor": {
      "type": "PropertyEditorPanel",
      "name": "PropertyEditor",
      "componentRendererRef": "renderer",
      "targetRef": "grid",
      "descriptionType": "DataGrid",
      "isHorizontal": true,
      "isWrappingEnabled": true,
      "properties": [
        {
          "type": "PropertyEditorPropertyDescription",
          "name": "LoadButton",
          "shouldOverrideDefaultEditor": true,
          "valueType": "Button",
          "primitiveValue": "Load",
          "buttonClickedRef": "DataGridLoadLayout"
        },
        {
          "type": "PropertyEditorPropertyDescription",
          "name": "SaveButton",
          "shouldOverrideDefaultEditor": true,
          "valueType": "Button",
          "primitiveValue": "Save",
          "buttonClickedRef": "DataGridSaveLayout"
        }
      ]
    },
    "aboveContent": {
      "type": "DataGridToolbar",
      "name": "toolbar",
      "id": "toolbar",
      "targetGridRef": "grid",
      "toolbarTitle": "Sales Team",
      "columnChooser": true,
      "columnPinning": true
    },
    "content": {
      "type": "DataGrid",
      "id": "grid",
      "name": "grid",
      "dataSourceRef": "EmployeesSalesData",
      "rowHeight": 50,
      "autoGenerateColumns": false,
      "isColumnOptionsEnabled": true,
      "defaultColumnMinWidth": 100,
      "summaryScope": "Root",
      "isGroupCollapsable": true,
      "groupHeaderDisplayMode": "Combined",
      "groupSummaryDisplayMode": "RowTop",
      "selectionMode": "SingleRow",
      "cornerRadiusTopLeft": 0,
      "cornerRadiusTopRight": 0,
      "columnMovingAnimationMode": "Auto",
      "height": "100%",
      "width": "100%",
      "groupDescriptions": [
        { "type": "ColumnGroupDescription", "field": "Country", "displayName": "Country" },
        { "type": "ColumnGroupDescription", "field": "Income",  "displayName": "Income"  }
      ],
      "summaryDescriptions": [
        { "type": "ColumnSummaryDescription", "field": "Photo",  "operand": "Count"   },
        { "type": "ColumnSummaryDescription", "field": "Sales",  "operand": "Max"     },
        { "type": "ColumnSummaryDescription", "field": "Salary", "operand": "Average" }
      ],
      "columns": [
        {
          "type": "ImageColumn",
          "field": "Photo",
          "headerText": "Photo",
          "width": { "type": "ColumnWidth", "isStarSized": false, "value": 110 },
          "contentOpacity": 1,
          "horizontalAlignment": "Center"
        },
        {
          "type": "TextColumn",
          "field": "Name",
          "width": { "type": "ColumnWidth", "isStarSized": true, "value": 1, "minimumWidth": 130 }
        },
        {
          "type": "NumericColumn",
          "field": "Sales",
          "headerText": "Sales",
          "width": { "type": "ColumnWidth", "isStarSized": true, "value": 1, "minimumWidth": 160 },
          "horizontalAlignment": "Center"
        },
        {
          "type": "NumericColumn",
          "field": "Salary",
          "width": { "type": "ColumnWidth", "isStarSized": true, "value": 1, "minimumWidth": 160 },
          "positivePrefix": "$",
          "showGroupingSeparator": true
        },
        {
          "type": "TextColumn",
          "field": "Address",
          "headerText": "Address",
          "width": { "type": "ColumnWidth", "isStarSized": true, "value": 1, "minimumWidth": 160 },
          "horizontalAlignment": "Left"
        },
        {
          "type": "ImageColumn",
          "field": "CountryFlag",
          "headerText": "Country",
          "width": { "type": "ColumnWidth", "isStarSized": false, "value": 130 },
          "contentOpacity": 1,
          "horizontalAlignment": "Stretch",
          "paddingTop": 7.5,
          "paddingBottom": 7.5
        },
        {
          "type": "DateTimeColumn",
          "field": "Birthday",
          "headerText": "Date of Birth",
          "width": { "type": "ColumnWidth", "isStarSized": true, "value": 1, "minimumWidth": 160 },
          "horizontalAlignment": "Right"
        },
        {
          "type": "TextColumn",
          "field": "Income",
          "width": { "type": "ColumnWidth", "isStarSized": true, "value": 1, "minimumWidth": 120 },
          "horizontalAlignment": "Center"
        },
        {
          "type": "TextColumn",
          "field": "Age",
          "width": { "type": "ColumnWidth", "isStarSized": true, "value": 1, "minimumWidth": 110 }
        }
      ]
    }
  },
  "modules": [
    "withDescriptions",
    "layouts/PropertyEditorPanelModule",
    "data-grids/DataGridModule",
    "data-grids/DataGridToolbarModule"
  ]
}
