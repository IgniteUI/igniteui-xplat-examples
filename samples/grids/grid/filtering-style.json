{
  "export": true,
  "todo": [ "" ],  
  "skipAlterDataCasing": true,
  "onInit": ["WebGridFilteringStyle"],
  "descriptions": {
    "editor": {
      "type": "PropertyEditorPanel",
      "name": "PropertyEditor",
      "componentRendererRef": "renderer",
      "targetRef": "grid",
      "descriptionType": "WebGrid",
      "isHorizontal": true,
      "isWrappingEnabled": true,
      "properties": [
        {
          "type": "PropertyEditorPropertyDescription",
          "name": "SizeEditor",
          "label": "Grid Size:",
          "valueType": "EnumValue",
          "dropDownNames": ["Small", "Medium", "Large"],
          "dropDownValues": ["Small", "Medium", "Large"],
          "changedRef": "WebGridSetGridSize"
        }
      ]
    },
    "content": {
      "type": "WebGrid",
      "name": "grid",
      "id": "grid",
      "dataRef": "NwindData",
      "moving": true,
      "autoGenerate": false,
      "allowFiltering": true,
      "filterMode": "ExcelStyleFilter",
      "toolbar": [
        {
          "type": "WebGridToolbar",
          "tools": [
            {
              "type": "WebGridToolbarActions",
              "actions": [
                {
                  "type": "WebGridToolbarHiding"
                }
              ]
            }
          ]
        }
      ],
      "columnList": [
        {
          "type": "WebColumn",
          "field": "ProductName",
          "header": "Product Name",
          "sortable": true
        },
        {
          "type": "WebColumn",
          "field": "QuantityPerUnit",
          "header": "Quantity Per Unit",
          "sortable": true
        },
        {
          "type": "WebColumn",
          "field": "UnitPrice",
          "header": "Unit Price",
          "dataType": "Currency",
          "sortable": true,
          "pipeArgs": {
            "type": "WebColumnPipeArgs",
            "digitsInfo": "1.2-2"
          }
        },
        {
          "type": "WebColumn",
          "field": "OrderDate",
          "header": "Order Date",
          "dataType": "Date",
          "sortable": true,
          "pipeArgs": {
            "type": "WebColumnPipeArgs",
            "format": "MM/dd/YYYY"
          }
        },
        {
          "type": "WebColumn",
          "field": "Discontinued",
          "header": "Discontinued",
          "sortable": true,
          "bodyTemplateRef": "WebGridBooleanCellTemplate"
        }
    ]
  }
},
"modules": [
  "withDescriptions",
  "layouts/PropertyEditorPanelModule",
  "grids/WebGridModule"
]
}
