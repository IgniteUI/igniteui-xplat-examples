{
  "descriptions": {
    "content": {
      "type": "DataChart",
      "name": "chart",
      "isHorizontalZoomEnabled": true,
      "isVerticalZoomEnabled": true,
      "chartTitle": "Public Debt vs. Population",
      "subtitle": "GDP per Capita",
      "axes": [
        {
          "type": "NumericXAxis",
          "name": "xAxis",
          "minimumValue": 10000,
          "maximumValue": 10000000000,
          "isLogarithmic": true,
          "abbreviateLargeNumbers": true,
          "title": "Population"
        },
        {
          "type": "NumericYAxis",
          "name": "yAxis",
          "title": "Public Debt per GDP (%)",
          "titleLeftMargin": 5,
          "isLogarithmic": false,
          "maximumValue": 120
        }
      ],
      "series": [
        {
          "type": "BubbleSeries",
          "name": "bubbleSeries1",
          "xMemberPath": "Population",
          "yMemberPath": "PublicDebt",
          "radiusMemberPath": "GdpPerPerson",
          "radiusScale": {
            "type": "SizeScale",
            "isLogarithmic": false,
            "minimumValue": 10,
            "maximumValue": 120
          },
          "fillMemberPath": "GdpPerPerson",
          "xAxisRef": "xAxis",
          "yAxisRef": "yAxis",
          "dataSourceRef": "WorldStats",
          "markerType": "Circle",
          "markerOutline": "black",
          "showDefaultTooltip": true,
          "fillScale": {
            "type": "ValueBrushScale",
            "isLogarithmic": false,
            "minimumValue": 0,
            "maximumValue": 260000,
            "brushes": ["#89b5fa", "#146cf7", "#5290f2"]
          }
        }
      ]
    }
  },
  "modules": [
    "withDescriptions",
    "charts/NumberAbbreviatorModule",
    "charts/DataChartCoreModule",
    "charts/DataChartScatterModule",
    "charts/DataChartScatterCoreModule",
    "charts/DataChartInteractivityModule",
    "charts/DataChartAnnotationModule"
  ]
}
